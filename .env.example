# Anthropic API key — https://console.anthropic.com
# Required for AI fix suggestions (--no-ai flag skips this)
ANTHROPIC_API_KEY=your_key_here

# GCP project ID — used by dry_run.py
# Alternatively pass via --project flag
GCP_PROJECT_ID=your-gcp-project
BQ_PRICE_PER_TB=6.25

# GitHub token — set automatically in GitHub Actions
# Only needed for local PR comment testing
GITHUB_TOKEN=your_token_here
GITHUB_REPOSITORY=owner/repo
